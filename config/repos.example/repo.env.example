# Copy this file to config/repos/<your-repo>.env for each repo you want to manage.
# Required fields (must be set):
REPO_PATH=/Users/vsinghthiara/Developer/Learning/your-repo
OWNER_REPO=your-github-username/your-repo
BASE_BRANCH=main
MODEL=ollama/qwen3-coder:30b

# Labels for issue tracking:
LABEL_TODO=agent-run
LABEL_RUNNING=agent-running
LABEL_DONE=agent-pr-created
LABEL_FAILED=agent-failed
LABEL_NO_CHANGES=agent-no-changes
LABEL_BLOCKED=agent-blocked

# Ollama API:
OLLAMA_API_BASE=http://localhost:11434

# Directories (use repo-specific paths to avoid conflicts):
LOG_DIR=/Users/vsinghthiara/Developer/Learning/agentic-pr/logs/your-repo
RUN_DIR=/Users/vsinghthiara/Developer/Learning/agentic-pr/var/run/your-repo
RUN_RECORD_DIR=/Users/vsinghthiara/Developer/Learning/agentic-pr/var/runs/your-repo
COMMENT_STATE_DIR=/Users/vsinghthiara/Developer/Learning/agentic-pr/var/comment-state/your-repo
LOCK_FILE=/Users/vsinghthiara/Developer/Learning/agentic-pr/var/run/your-repo/agent.lock

# Polling:
POLL_INTERVAL_SECONDS=300

# Agent identification:
AGENT_HOST_LABEL=Mac Studio

# GitHub commenting:
COMMENT_ON_START=true
COMMENT_ON_SUCCESS=true
COMMENT_ON_FAILURE=true
COMMENT_ON_NO_CHANGES=true

# Aider settings:
AIDER_EXTRA_ARGS=
AIDER_TIMEOUT_SECONDS=1800
MAX_CHANGED_FILES=20
MAX_DIFF_LINES=800
REQUIRE_AIDERIGNORE=true
BLOCKED_PATH_PATTERNS=.env,.env.*,*.pem,*.key,*.p12,*.pfx,secrets/*,credentials/*,node_modules/*,.venv/*,dist/*,build/*,**pycache**/*

# Test and lint commands (can be overridden by .agentic-pr/commands.env):
TEST_CMD=
LINT_CMD=

# Stale lock detection:
STALE_LOCK_SECONDS=7200

# Planner:
ENABLE_PLANNER=true
PLANNER_MODEL=ollama/qwen3-coder:30b
REPO_CONTEXT_MAX_FILES=80
REPO_CONTEXT_MAX_BYTES=120000
PLANNER_TIMEOUT_SECONDS=900
COMMENT_PLAN=true

# Rev 08: PR follow-up
ENABLE_PR_FOLLOWUPS=true
PR_FOLLOWUP_COMMAND_PREFIX=/agent
PR_FOLLOWUP_REQUIRE_LABEL=false
LABEL_FOLLOWUP=agent-followup
LABEL_FOLLOWUP_RUNNING=agent-followup-running
LABEL_FOLLOWUP_DONE=agent-followup-done
LABEL_FOLLOWUP_FAILED=agent-followup-failed
MAX_FOLLOWUP_COMMENTS_PER_CYCLE=1

# Rev 09: CI-aware PR follow-up
ENABLE_CI_CONTEXT=true
CI_COMMAND_ALIASES=/agent fix-ci,/agent fix checks,/agent fix failing tests
CI_LOG_MAX_LINES=250
CI_LOG_MAX_BYTES=40000
CI_INCLUDE_SUCCESSFUL_CHECKS=false
CI_REQUIRE_FAILED_CHECKS=false

# Rev 10: Repo instructions
ENABLE_REPO_INSTRUCTIONS=true
REPO_INSTRUCTIONS_DIR=.agentic-pr
REPO_INSTRUCTIONS_MAX_BYTES=40000

# Rev 11: Maintenance and cleanup
RUN_RETENTION_DAYS=30
LOG_RETENTION_DAYS=30
PROMPT_RETENTION_DAYS=30
COMMENT_STATE_RETENTION_DAYS=90
MAX_LOG_PREVIEW_LINES=80
SERVICE_LABEL=com.veer.agentic-pr.your-repo

# Rev 12: Multi-repo config registry
# Set to false to disable this repo from list-configs, doctor-all, health-all
ENABLED=true
# Rev 13: Coding engine abstraction
ENGINE=aider
ENGINE_TIMEOUT_SECONDS=1800

# Rev 14: Experimental OpenHands engine
OPENHANDS_COMMAND=openhands
OPENHANDS_TIMEOUT_SECONDS=3600
OPENHANDS_EXTRA_ARGS=
OPENHANDS_USE_JSON_OUTPUT=false
OPENHANDS_EXPERIMENTAL=false
OPENHANDS_LLM_BASE_URL=http://host.docker.internal:11434/v1
OPENHANDS_API_KEY=local-llm
OPENHANDS_DOCKER_IMAGE=docker.openhands.dev/openhands/openhands:1.8
OPENHANDS_PERSISTENCE_DIR=/Users/vsinghthiara/Developer/Learning/agentic-pr/var/openhands/your-repo
