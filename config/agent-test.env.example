# Copy this file to config/agent-test.env for local test runs.

REPO_PATH=/Users/vsinghthiara/Documents/Learning/agent-test
OWNER_REPO=veerthiara/agent-test-local-ai
BASE_BRANCH=main
MODEL=ollama/qwen3-coder:30b

LABEL_TODO=agent-run
LABEL_RUNNING=agent-running
LABEL_DONE=agent-pr-created
LABEL_FAILED=agent-failed

OLLAMA_API_BASE=http://localhost:11434

LOG_DIR=/Users/vsinghthiara/Documents/Learning/agentic-pr/logs
RUN_DIR=/Users/vsinghthiara/Documents/Learning/agentic-pr/var/run
POLL_INTERVAL_SECONDS=300
LOCK_FILE=/Users/vsinghthiara/Documents/Learning/agentic-pr/var/run/agent-test.lock
AIDER_EXTRA_ARGS=
