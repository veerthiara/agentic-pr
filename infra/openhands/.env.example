# Docker Compose environment variables
# Copy this file to .env and adjust for your machine.

# Repository path (absolute path on host)
OPENHANDS_REPO_PATH=/absolute/path/to/your/repo

# Persistence directory on host
OPENHANDS_PERSISTENCE_DIR=${HOME}/.openhands-agentic-pr

# LLM Configuration
# For OpenHands/LiteLLM + Ollama, include the provider prefix: ollama/
# Do not use /v1 here when using the native LiteLLM Ollama provider prefix `ollama/`.
# Do not enable reasoning/thinking options for qwen3-coder:30b in the OpenHands UI profile.
LLM_MODEL=ollama/qwen3-coder:30b
LLM_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=local-llm

# Container memory limits
# Note: Colima must be started with enough VM memory for these to apply.
OPENHANDS_WEB_MEMORY_LIMIT=6g
OPENHANDS_WEB_MEMORY_SWAP_LIMIT=8g